# Server
SERVER_PORT=8080

# Telegram TDLib
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE_NUMBER=+79990000000

# Telegram -> VK mapping
TG_CHANNEL_1_ID=-1001234567890
TG_CHANNEL_1_NAME=news-main
VK_COMMUNITY_1_ID=12345678
VK_COMMUNITY_1_NAME=vk-main

TG_CHANNEL_2_ID=-1009876543210
TG_CHANNEL_2_NAME=news-second
VK_COMMUNITY_2_ID=87654321
VK_COMMUNITY_2_NAME=vk-second

# VK
VK_TOKEN=vk_service_token
VK_API_VERSION=5.199
VK_API_URL=https://api.vk.com/method

# State storage
APP_STATE_FILE_PATH=./data/state-store.txt
APP_STATE_RETENTION_DAYS=5
APP_STATE_CLEANUP_INTERVAL_MS=3600000

# Retry
APP_RETRY_MAX_ATTEMPTS=3
APP_RETRY_INITIAL_BACKOFF=PT1S
APP_RETRY_MULTIPLIER=2.0

# Notifications
APP_NOTIFICATIONS_ENABLED=false
APP_NOTIFICATIONS_BOT_TOKEN=
APP_NOTIFICATIONS_TARGET_CHAT_ID=

# Formatting / events / sync
APP_FORMATTING_SOURCE_LINK_TEXT=ЭмоциON
APP_EVENTS_MAX_IN_MEMORY=500
APP_SYNC_FIXED_DELAY_MS=5000
